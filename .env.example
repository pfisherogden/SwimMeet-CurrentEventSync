# --- SECURE REDIRECTOR CONFIGURATION ---
# The ID of your Master Google Sheet (see docs/RedirectorSetup.md)
MASTER_SHEET_ID=your_master_sheet_id

# The URL of your deployed Redirector.js Web App
REDIRECTOR_WEB_APP_URL=https://script.google.com/macros/s/.../exec

# Your team ID and secret (used for the permanent QR code)
TEAM_ID=dolphin
SHARED_SECRET=your_secret_here

# --- FRONTEND CONFIGURATION ---
# The base URL of your GitHub Pages app
GITHUB_PAGES_URL=https://pfisherogden.github.io/SwimMeet-CurrentEventSync/
